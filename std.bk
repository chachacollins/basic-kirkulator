# Basic Kirkulator STDLIB
PI    = 3.14159265358979323846
e     = 2.71828182845904523536
trunc = \n   -> n - n % 1
floor = \n   -> n - ((n % 1) + 1) % 1
ceil  = \n   -> n + (1 - n % 1) % 1
round = \n   -> floor(n + 0.5)
abs   = \n   -> (n * n) ** 0.5
sqrt  = \n   -> n ** 0.5
cbrt  = \n   -> n ** (1 / 3)
sq    = \n   -> n * n
cube  = \n   -> n * n * n
recip = \n   -> 1 / n
lerp  = \a b t -> a + (b - a) * t
